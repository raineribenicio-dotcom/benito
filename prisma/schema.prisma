// Nuvora — E-commerce multi-categoría
// Schema Prisma. Patrón inspirado en Shopify: Product → Variant → Option/Value,
// catálogo flexible por categoría (atributos tipados + JSONB), multi-moneda,
// i18n por tablas de traducción, suscripciones y CRO (reviews, Q&A, wishlist).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AttributeType {
  STRING
  NUMBER
  BOOLEAN
  DIMENSION // valor + unidad (p.ej. "15 in")
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum OrderStatus {
  PENDING        // creado, esperando pago
  PAID
  FULFILLING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIAL
  FULFILLED
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  RETURNED
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  RECEIVED
  REFUNDED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum SubscriptionInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

// ----------------------------------------------------------------------------
// Auth (Auth.js / NextAuth)
// ----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(CUSTOMER)
  passwordHash  String? // null cuando sólo usa OAuth
  locale        String    @default("es")
  currency      String    @default("EUR")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  addresses     Address[]
  carts         Cart[]
  orders        Order[]
  reviews       Review[]
  questions     Question[]
  answers       Answer[]
  wishlist      Wishlist?
  subscriptions Subscription[]
  paymentMethods PaymentMethod[]
  auditLogs     AuditLog[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  firstName  String
  lastName   String
  company    String?
  line1      String
  line2      String?
  city       String
  province   String?
  postalCode String
  country    String // ISO 3166-1 alpha-2
  phone      String?
  isDefault  Boolean @default(false)

  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingForOrders Order[] @relation("OrderShippingAddress")
  billingForOrders  Order[] @relation("OrderBillingAddress")

  @@index([userId])
}

// Token de método de pago (PCI: el dato real vive en el proveedor, aquí sólo refs)
model PaymentMethod {
  id                String          @id @default(cuid())
  userId            String
  provider          PaymentProvider
  providerRef       String // p.ej. Stripe PaymentMethod id
  brand             String? // visa, mastercard...
  last4             String?
  expMonth          Int?
  expYear           Int?
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ----------------------------------------------------------------------------
// Catálogo
// ----------------------------------------------------------------------------

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  parentId    String?
  position    Int     @default(0)
  imageUrl    String?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products            ProductCategory[]
  attributeDefinitions AttributeDefinition[]
  translations        CategoryTranslation[]

  @@index([parentId])
}

model CategoryTranslation {
  id          String  @id @default(cuid())
  categoryId  String
  locale      String
  name        String
  description String?

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
}

model Brand {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  logoUrl  String?
  products Product[]
}

// Define qué atributos (fichas técnicas) aplican a una categoría: lo que permite
// que Moda, Electrónica, Belleza... tengan campos distintos sin tocar el esquema.
model AttributeDefinition {
  id          String        @id @default(cuid())
  categoryId  String
  key         String // p.ej. "ram", "material", "spf"
  label       String
  type        AttributeType @default(STRING)
  unit        String? // para DIMENSION/NUMBER: "GB", "ml"...
  filterable  Boolean       @default(false)
  position    Int           @default(0)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, key])
}

model Product {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  description     String?
  status          ProductStatus @default(DRAFT)
  brandId         String?
  // Atributos flexibles desnormalizados para filtrado/búsqueda rápida (GIN index app-side)
  attributes      Json          @default("{}")
  ratingAverage   Float         @default(0)
  ratingCount     Int           @default(0)
  // SEO
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  brand        Brand?               @relation(fields: [brandId], references: [id])
  categories   ProductCategory[]
  variants     ProductVariant[]
  options      ProductOption[]
  media        Media[]
  translations ProductTranslation[]
  collections  CollectionProduct[]
  reviews      Review[]
  questions    Question[]
  attributeValues ProductAttributeValue[]
  relatedFrom  RelatedProduct[]    @relation("RelatedFrom")
  relatedTo    RelatedProduct[]    @relation("RelatedTo")

  @@index([status])
  @@index([brandId])
}

model ProductTranslation {
  id              String  @id @default(cuid())
  productId       String
  locale          String
  title           String
  description     String?
  metaTitle       String?
  metaDescription String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

// Valor tipado de un atributo para un producto concreto (ficha técnica)
model ProductAttributeValue {
  id          String  @id @default(cuid())
  productId   String
  key         String
  valueString String?
  valueNumber Float?
  valueBool   Boolean?
  unit        String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, key])
  @@index([key])
}

// Opciones de variación a nivel de producto: Talla, Color...
model ProductOption {
  id        String              @id @default(cuid())
  productId String
  name      String
  position  Int                 @default(0)

  product Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  ProductOptionValue[]

  @@unique([productId, name])
}

model ProductOptionValue {
  id       String @id @default(cuid())
  optionId String
  value    String // p.ej. "M", "Rojo"
  position Int    @default(0)

  option           ProductOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variantSelections VariantOptionValue[]

  @@unique([optionId, value])
}

model ProductVariant {
  id          String  @id @default(cuid())
  productId   String
  sku         String  @unique
  barcode     String?
  // Precio "base" en la moneda por defecto; multi-moneda en VariantPrice
  priceAmount Int // céntimos
  compareAt   Int? // precio tachado para mostrar descuento
  currency    String  @default("EUR")
  weightGrams Int?
  position    Int     @default(0)
  imageId     String?

  product       Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  image         Media?               @relation(fields: [imageId], references: [id])
  optionValues  VariantOptionValue[]
  prices        VariantPrice[]
  stockLevels   StockLevel[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  subscriptions Subscription[]

  @@index([productId])
}

model VariantOptionValue {
  variantId     String
  optionValueId String

  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
}

model VariantPrice {
  id        String @id @default(cuid())
  variantId String
  currency  String
  amount    Int // céntimos
  compareAt Int?

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, currency])
}

model Media {
  id        String  @id @default(cuid())
  productId String?
  url       String
  alt       String?
  width     Int?
  height    Int?
  position  Int     @default(0)
  // Provider info (Cloudinary public_id / S3 key) para transformaciones
  providerRef String?

  product  Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@index([productId])
}

model RelatedProduct {
  fromId String
  toId   String
  kind   String @default("related") // "related" | "bought_together"

  from Product @relation("RelatedFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Product @relation("RelatedTo", fields: [toId], references: [id], onDelete: Cascade)

  @@id([fromId, toId, kind])
}

// ----------------------------------------------------------------------------
// Colecciones / Merchandising
// ----------------------------------------------------------------------------

model Collection {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String?
  imageUrl    String?
  isFeatured  Boolean @default(false)
  position    Int     @default(0)

  products CollectionProduct[]
}

model CollectionProduct {
  collectionId String
  productId    String
  position     Int    @default(0)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
}

// ----------------------------------------------------------------------------
// Inventario
// ----------------------------------------------------------------------------

model Location {
  id          String       @id @default(cuid())
  name        String
  country     String?
  isActive    Boolean      @default(true)
  stockLevels StockLevel[]
}

model StockLevel {
  id         String @id @default(cuid())
  variantId  String
  locationId String
  available  Int    @default(0)
  reserved   Int    @default(0)

  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  location Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([variantId, locationId])
}

// ----------------------------------------------------------------------------
// Carrito
// ----------------------------------------------------------------------------

model Cart {
  id         String     @id @default(cuid())
  userId     String?
  // Para invitados: token en cookie httpOnly
  token      String     @unique @default(cuid())
  status     CartStatus @default(ACTIVE)
  currency   String     @default("EUR")
  email      String?
  couponCode String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  // Para recuperación de carrito abandonado
  remindedAt DateTime?

  user  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items CartItem[]

  @@index([userId])
  @@index([status])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int    @default(1)
  // Snapshot de precio en el momento de añadir (céntimos)
  unitPrice Int

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
}

// ----------------------------------------------------------------------------
// Pedidos
// ----------------------------------------------------------------------------

model Order {
  id                String            @id @default(cuid())
  number            String            @unique // legible: #1001
  userId            String?
  email             String
  status            OrderStatus       @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)
  currency          String            @default("EUR")

  // Importes en céntimos
  subtotal       Int
  discountTotal  Int @default(0)
  shippingTotal  Int @default(0)
  taxTotal       Int @default(0)
  total          Int

  couponCode        String?
  shippingAddressId String?
  billingAddressId  String?
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  shippingAddress Address?    @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?    @relation("OrderBillingAddress", fields: [billingAddressId], references: [id])
  items           OrderItem[]
  payments        Payment[]
  shipments       Shipment[]
  returns         Return[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  variantId String?
  // Snapshot: el pedido conserva el detalle aunque cambie el catálogo
  title     String
  variantTitle String?
  sku       String
  quantity  Int
  unitPrice Int // céntimos
  total     Int

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  returnItems ReturnItem[]

  @@index([orderId])
}

model Payment {
  id          String          @id @default(cuid())
  orderId     String
  provider    PaymentProvider
  providerRef String // PaymentIntent id / PayPal capture id
  status      PaymentStatus   @default(PROCESSING)
  amount      Int
  currency    String
  refunded    Int             @default(0)
  createdAt   DateTime        @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([providerRef])
}

model Shipment {
  id            String         @id @default(cuid())
  orderId       String
  status        ShipmentStatus @default(PENDING)
  carrier       String?
  trackingCode  String?
  trackingUrl   String?
  shippedAt     DateTime?
  deliveredAt   DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Return {
  id        String       @id @default(cuid())
  orderId   String
  status    ReturnStatus @default(REQUESTED)
  reason    String?
  refundAmount Int       @default(0)
  createdAt DateTime     @default(now())

  order Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items ReturnItem[]

  @@index([orderId])
}

model ReturnItem {
  id          String @id @default(cuid())
  returnId    String
  orderItemId String
  quantity    Int

  return    Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
}

// ----------------------------------------------------------------------------
// Promociones
// ----------------------------------------------------------------------------

model Discount {
  id              String       @id @default(cuid())
  code            String       @unique
  type            DiscountType
  value           Int // porcentaje (0-100) o céntimos según type
  minSubtotal     Int? // umbral mínimo en céntimos
  usageLimit      Int?
  usageCount      Int          @default(0)
  perCustomerLimit Int?
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([code])
}

// ----------------------------------------------------------------------------
// Suscripciones (recompra — clave en belleza/salud)
// ----------------------------------------------------------------------------

model Subscription {
  id           String               @id @default(cuid())
  userId       String
  variantId    String
  quantity     Int                  @default(1)
  interval     SubscriptionInterval @default(MONTHLY)
  status       SubscriptionStatus   @default(ACTIVE)
  providerRef  String? // Stripe Subscription id
  nextOrderAt  DateTime
  createdAt    DateTime             @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([userId])
  @@index([status])
}

// ----------------------------------------------------------------------------
// Social / CRO
// ----------------------------------------------------------------------------

model Review {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  rating     Int // 1-5
  title      String?
  body       String?
  isApproved Boolean  @default(false)
  isVerified Boolean  @default(false) // compra verificada
  createdAt  DateTime @default(now())

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  media   ReviewMedia[]

  @@unique([productId, userId])
  @@index([productId])
}

model ReviewMedia {
  id       String @id @default(cuid())
  reviewId String
  url      String
  alt      String?

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Question {
  id        String   @id @default(cuid())
  productId String
  userId    String
  body      String
  createdAt DateTime @default(now())

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([productId])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  userId     String
  body       String
  isStaff    Boolean  @default(false)
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id     String         @id @default(cuid())
  userId String         @unique
  items  WishlistItem[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id         String @id @default(cuid())
  wishlistId String
  variantId  String

  wishlist Wishlist       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, variantId])
}

// ----------------------------------------------------------------------------
// Admin / Auditoría
// ----------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // "product.update", "order.refund"...
  entity    String
  entityId  String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([createdAt])
}
