# ----------------------------------------------------------------------------
# Benito — variables de entorno. Copia a .env.local y rellena.
# Las integraciones externas están abstraídas: si no defines la clave de un
# proveedor, la app usa un fallback (búsqueda en Postgres, imágenes locales,
# pagos en modo stub) para poder desarrollar sin cuentas.
# ----------------------------------------------------------------------------

# Base de datos (PostgreSQL gestionado: Neon, Supabase, RDS...)
DATABASE_URL="postgresql://user:password@localhost:5432/benito?schema=public"

# Auth.js
AUTH_SECRET="genera-con: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
# OAuth (opcional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Stripe (modo test). Si vacío => proveedor de pago en modo stub.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# PayPal (opcional)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# Algolia (opcional). Si vacío => búsqueda con fallback en Postgres.
ALGOLIA_APP_ID=""
ALGOLIA_ADMIN_KEY=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""
NEXT_PUBLIC_ALGOLIA_INDEX="products"

# Imágenes — Cloudinary (opcional). Si vacío => URLs directas.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email — Resend (opcional). Si vacío => emails se loguean en consola.
RESEND_API_KEY=""
EMAIL_FROM="Benito <hola@benito.shop>"

# Cron de recuperación de carrito abandonado. Vercel Cron envía
# Authorization: Bearer <CRON_SECRET>. Si vacío, el endpoint queda deshabilitado.
CRON_SECRET=""

# Tienda
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_CURRENCY="EUR"
NEXT_PUBLIC_DEFAULT_LOCALE="es"
